{
  "name": "hyxclaw",
  "version": "0.1.0",
  "description": "Personal AI Assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hyxclaw": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/server/public",
    "docs"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js start",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:config": "node scripts/test-config.js",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "assistant",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.16.0"
  },
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "@tavily/core": "^0.7.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "katex": "^0.16.45",
    "lucide": "^1.25.0",
    "markdown-it": "^14.1.1",
    "sharp": "^0.35.3",
    "tslog": "^4.10.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "oxfmt": "0.38.0",
    "oxlint": "^1.55.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
